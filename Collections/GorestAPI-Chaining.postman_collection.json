  "item": [
    {
      "name": "Create user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var random = Math.floor(Math.random() * 1000000); // ensures numeric suffix\r",
              "var usermail = \"test\" + random + \"@gmail.com\";\r",
              "var username = \"test\" + random;\r",
              "\r",
              "pm.environment.set(\"email_env\", usermail);\r",
              "pm.environment.set(\"name_env\", username);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse the response body as JSON\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "// Access the \"id\" field\r",
              "pm.environment.set(\"userid_env\", jsonData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "  {\r\n    \"name\": \"{{name_env}}\",\r\n    \"email\": \"{{email_env}}\",\r\n    \"gender\": \"male\",\r\n    \"status\": \"active\"\r\n  }",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://gorest.co.in/public/v2/users",
          "protocol": "https",
          "host": [
            "gorest",
            "co",
            "in"
          ],
          "path": [
            "public",
            "v2",
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//validating the json fileds in the response\r",
              "pm.test(\"Valuses of json fileds\",  () =>\r",
              "{\r",
              "    var jsonData = pm.response.json();\r",
              "\r",
              "    pm.environment.get(\"userid_env\");\r",
              "\r",
              "    pm.expect(jsonData.id).to.eql(pm.environment.get(\"userid_env\"));\r",
              "   \r",
              "\r",
              "    pm.expect(jsonData.email).to.eql(pm.environment.get(\"email_env\"));\r",
              "\r",
              "   \r",
              "    pm.expect(jsonData.name).to.eql(pm.environment.get(\"name_env\"));\r",
              "    }\r",
              ");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
