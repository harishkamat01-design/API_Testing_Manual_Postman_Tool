      "name": "Student Folder",
      "item": [
        {
          "name": "Get Single Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log(\"Post-response script at request level\")\r",
                  "\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "//--------------------------------------------------------------------------------------\r",
                  "pm.test(\"Content-Type is present\", function () {\r",
                  "    pm.response.to.have.header(\"Content-Type\");\r",
                  "});\r",
                  "//-------------------------------------------------------------------------------------\r",
                  "pm.test(\"Response time is less than 200ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "//--------------------------------------------------------------------------------------\r",
                  "pm.test(\"Content-Type header is application/json\", () => {\r",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.eql('application/json');\r",
                  "});\r",
                  "//--------------------------------------------------------------------------------------\r",
                  "const jsonData = pm.response.json();\r",
                  "pm.test(\"Test data type of the response\", () => {\r",
                  "    pm.expect(jsonData).to.be.an(\"object\");\r",
                  "    pm.expect(jsonData.name).to.be.a(\"string\");\r",
                  "    pm.expect(jsonData.id).to.be.a(\"string\");\r",
                  "    pm.expect(jsonData.course).to.be.an(\"string\");\r",
                  "});\r",
                  "//--------------------------------------------------------------------------------------\r",
                  "pm.test(\"Test course field\", () => {\r",
                  "    var jsonData = pm.response.json();\r",
                  "\r",
                  "    // Directly check the course field\r",
                  "    pm.expect(jsonData.course).to.eql(\"Computer Science\");\r",
                  "\r",
                  "    // Or check if course is one of multiple allowed values\r",
                  "    pm.expect(jsonData.course).to.be.oneOf([\"Computer Science\", \"Selenium\"]);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "//--------------------------------------------------------------------------------------\r",
                  "pm.test(\"Validate single student response\", () => {\r",
                  "  var jsonData = pm.response.json();\r",
                  "\r",
                  "  pm.expect(jsonData.id).to.eql(\"9961\");  // id is a string\r",
                  "  pm.expect(jsonData.name).to.eql(\"Aarav Goswami\"); // remove trailing space\r",
                  "  pm.expect(jsonData.age).to.eql(21);     // match actual value\r",
                  "  pm.expect(jsonData.course).to.eql(\"Computer Science\");\r",
                  "  pm.expect(jsonData.email).to.eql(\"aarav.goswami@example.com\"); // match actual email\r",
                  "});\r",
                  "\r",
                  "//--------------------------------------------------------------------------------------\r",
                  "const schema = {\r",
                  "    \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r",
                  "    \"title\": \"Student Schema\",\r",
                  "    \"type\": \"object\",\r",
                  "    \"properties\": {\r",
                  "        \"id\": { \"type\": \"string\" },\r",
                  "        \"name\": { \"type\": \"string\" },\r",
                  "        \"age\": { \"type\": \"integer\", \"minimum\": 18, \"maximum\": 100 },\r",
                  "        \"course\": { \"type\": \"string\" },\r",
                  "        \"email\": { \"type\": \"string\", \"format\": \"email\" }\r",
                  "    },\r",
                  "    \"required\": [\"id\", \"name\", \"age\", \"course\", \"email\"],\r",
                  "    \"additionalProperties\": false\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Validate single student JSON schema\", function () {\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "console.log(\"Pre-request script at request level\")"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{url_collect}}students/9961",
              "host": [
                "{{url_collect}}students"
              ],
              "path": [
                "9961"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get All Students",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "//==================================================================================",
                  "pm.test(\"Content-Type is present\", function () {",
                  "    pm.response.to.have.header(\"Content-Type\");",
                  "});",
                  "//==================================================================================",
                  "pm.test(\"Response time is less than 200ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "//==================================================================================",
                  "",
                  "pm.test(\"Content-Type header is application/json\", () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.eql('application/json');",
                  "});",
                  "//==================================================================================",
                  "",
                  "const jsonData = pm.response.json();",
                  "",
                  "pm.test(\"Validate all students\", () => {",
                  "    pm.expect(jsonData).to.be.an(\"array\");",
                  "",
                  "    jsonData.forEach(student => {",
                  "        pm.expect(student).to.be.an(\"object\");",
                  "        pm.expect(student.id).to.be.a(\"string\");",
                  "        pm.expect(student.name).to.be.a(\"string\");",
                  "        pm.expect(student.course).to.be.a(\"string\");",
                  "    });",
                  "});",
                  "",
                  "//==================================================================================",
                  "pm.test(\"Course is one of expected values\", () => {",
                  "    var jsonData = pm.response.json();",
                  "    var student = jsonData[0];",
                  "",
                  "    pm.expect(student.course).to.be.oneOf([\"Computer Science\", \"Selenium\"]);",
                  "});",
                  "//==================================================================================",
                  "pm.test(\"value of name field is Aarav\", () => {",
                  "  var jsonData = pm.response.json();",
                  "",
                  "  // If the response is an array of students, pick the first one",
                  "  var student = jsonData[0];",
                  "",
                  "  pm.expect(student.id).to.eql(\"1\");  // id is a string in your JSON",
                  "  pm.expect(student.name).to.eql(\"Aarav Sharma\");",
                  "  pm.expect(student.age).to.eql(20);",
                  "  pm.expect(student.course).to.eql(\"Computer Science\");",
                  "  pm.expect(student.email).to.eql(\"aarav.sharma@example.com\");",
                  "});",
                  "//==================================================================================",
                  "",
                  "pm.test(\"Validate all students\", () => {",
                  "    pm.expect(jsonData).to.be.an(\"array\");",
                  "",
                  "    jsonData.forEach(student => {",
                  "        pm.expect(student).to.be.an(\"object\");",
                  "        pm.expect(student.name).to.be.a(\"string\");",
                  "        pm.expect(student.id).to.be.a(\"string\");",
                  "        pm.expect(student.course).to.be.a(\"string\");",
                  "    });",
                  "});",
                  "//=================================================================================="
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
