    {
      "name": "Get Single Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "//--------------------------------------------------------------------------------------\r",
              "pm.test(\"Content-Type is present\", function () {\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "});\r",
              "//-------------------------------------------------------------------------------------\r",
              "pm.test(\"Response time is less than 200ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "//--------------------------------------------------------------------------------------\r",
              "pm.test(\"Content-Type header is application/json\", () => {\r",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.eql('application/json');\r",
              "});\r",
              "//--------------------------------------------------------------------------------------\r",
              "const jsonData = pm.response.json();\r",
              "pm.test(\"Test data type of the response\", () => {\r",
              "    pm.expect(jsonData).to.be.an(\"object\");\r",
              "    pm.expect(jsonData.name).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.id).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.course).to.be.an(\"string\");\r",
              "});\r",
              "//--------------------------------------------------------------------------------------\r",
              "pm.test(\"Test course field\", () => {\r",
              "    var jsonData = pm.response.json();\r",
              "\r",
              "    // Directly check the course field\r",
              "    pm.expect(jsonData.course).to.eql(\"Computer Science\");\r",
              "\r",
              "    // Or check if course is one of multiple allowed values\r",
              "    pm.expect(jsonData.course).to.be.oneOf([\"Computer Science\", \"Selenium\"]);\r",
              "});\r",
              "\r",
              "\r",
              "//--------------------------------------------------------------------------------------\r",
              "pm.test(\"Validate single student response\", () => {\r",
              "  var jsonData = pm.response.json();\r",
              "\r",
              "  pm.expect(jsonData.id).to.eql(\"9961\");  // id is a string\r",
              "  pm.expect(jsonData.name).to.eql(\"Aarav Goswami\"); // remove trailing space\r",
              "  pm.expect(jsonData.age).to.eql(21);     // match actual value\r",
              "  pm.expect(jsonData.course).to.eql(\"Computer Science\");\r",
              "  pm.expect(jsonData.email).to.eql(\"aarav.goswami@example.com\"); // match actual email\r",
              "});\r",
              "\r",
              "//--------------------------------------------------------------------------------------\r",
              "const schema = {\r",
              "    \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r",
              "    \"title\": \"Student Schema\",\r",
              "    \"type\": \"object\",\r",
              "    \"properties\": {\r",
              "        \"id\": { \"type\": \"string\" },\r",
              "        \"name\": { \"type\": \"string\" },\r",
              "        \"age\": { \"type\": \"integer\", \"minimum\": 18, \"maximum\": 100 },\r",
              "        \"course\": { \"type\": \"string\" },\r",
              "        \"email\": { \"type\": \"string\", \"format\": \"email\" }\r",
              "    },\r",
              "    \"required\": [\"id\", \"name\", \"age\", \"course\", \"email\"],\r",
              "    \"additionalProperties\": false\r",
              "};\r",
              "\r",
              "pm.test(\"Validate single student JSON schema\", function () {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
