  "item": [
    {
      "name": "Get All Students",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "//==================================================================================",
              "pm.test(\"Content-Type is present\", function () {",
              "    pm.response.to.have.header(\"Content-Type\");",
              "});",
              "//==================================================================================",
              "pm.test(\"Response time is less than 200ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "//==================================================================================",
              "",
              "pm.test(\"Content-Type header is application/json\", () => {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.eql('application/json');",
              "});",
              "//==================================================================================",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Validate all students\", () => {",
              "    pm.expect(jsonData).to.be.an(\"array\");",
              "",
              "    jsonData.forEach(student => {",
              "        pm.expect(student).to.be.an(\"object\");",
              "        pm.expect(student.id).to.be.a(\"string\");",
              "        pm.expect(student.name).to.be.a(\"string\");",
              "        pm.expect(student.course).to.be.a(\"string\");",
              "    });",
              "});",
              "",
              "//==================================================================================",
              "pm.test(\"Course is one of expected values\", () => {",
              "    var jsonData = pm.response.json();",
              "    var student = jsonData[0];",
              "",
              "    pm.expect(student.course).to.be.oneOf([\"Computer Science\", \"Selenium\"]);",
              "});",
              "//==================================================================================",
              "pm.test(\"value of name field is Aarav\", () => {",
              "  var jsonData = pm.response.json();",
              "",
              "  // If the response is an array of students, pick the first one",
              "  var student = jsonData[0];",
              "",
              "  pm.expect(student.id).to.eql(\"1\");  // id is a string in your JSON",
              "  pm.expect(student.name).to.eql(\"Aarav Sharma\");",
              "  pm.expect(student.age).to.eql(20);",
              "  pm.expect(student.course).to.eql(\"Computer Science\");",
              "  pm.expect(student.email).to.eql(\"aarav.sharma@example.com\");",
              "});",
              "//==================================================================================",
              "",
              "pm.test(\"Validate all students\", () => {",
              "    pm.expect(jsonData).to.be.an(\"array\");",
              "",
              "    jsonData.forEach(student => {",
              "        pm.expect(student).to.be.an(\"object\");",
              "        pm.expect(student.name).to.be.a(\"string\");",
              "        pm.expect(student.id).to.be.a(\"string\");",
              "        pm.expect(student.course).to.be.a(\"string\");",
              "    });",
              "});",
              "//=================================================================================="
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
